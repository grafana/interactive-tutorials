.hippo
repository.json
graph.json
.DS_Store

# CI-generated snippet catalog — built by `pathfinder-cli build-snippets`
# during the deploy workflow. Author the snippet bodies (shared/snippets/<id>.json);
# let CI rebuild this index.
shared/snippets/index.json

# CI-generated course platform indexes — built by `pathfinder-cli build-courses`
# during the deploy workflow. Hand-edit the per-course `course.json` and
# `badges.json` files; let CI rebuild these.
courses/oss.json
courses/cloud.json

# Browser-automation session/cache directories
scripts/.browser-session/
**/.browser-session/

# LP PR review skill — local state (findings, review body, GraphQL IDs)
.cursor/pr-review-state/

# LP preflight skill — local state (findings, claim-check, readiness). Never commit.
.cursor/lp-preflight-state/

# audit-guide skill output — review-time artifacts; never commit (see review-learning-path SKILL.md)
**/assets/audit-input.json
**/assets/audit-report.md
**/assets/structural-report.md
**/assets/semantic-report.md
**/assets/adversarial-report.md
**/assets/history/

# Python
__pycache__/
*.py[cod]
