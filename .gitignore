.hippo
repository.json
graph.json
.DS_Store

# CI-generated course platform indexes — built by `pathfinder-cli build-courses`
# during the deploy workflow. Hand-edit the per-course `course.json` and
# `badges.json` files; let CI rebuild these.
courses/oss.json
courses/cloud.json

# CI-generated snippet catalog — built by `scripts/build-snippets-index.py`
# during the deploy workflow. Hand-edit the per-snippet `<id>.json` bodies;
# the catalog is regenerated from them at deploy time.
shared/snippets/index.json

# Browser-automation session/cache directories
scripts/.browser-session/
**/.browser-session/

# Python
__pycache__/
*.py[cod]
