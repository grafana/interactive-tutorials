{
  "id": "metrics-drilldown-nav",
  "title": "Navigate to Metrics Drilldown",
  "description": "A multistep snippet for navigating to Drilldown > Metrics from the main menu.",
  "blocks": [
    {
      "type": "multistep",
      "content": "Click **Drilldown > Metrics** to open Metrics Drilldown.",
      "steps": [
        {
          "action": "highlight",
          "reftarget": "button[aria-label='Expand section: Drilldown']"
        },
        {
          "action": "highlight",
          "reftarget": "a[data-testid='data-testid Nav menu item'][href='/a/grafana-metricsdrilldown-app/drilldown']"
        }
      ],
      "requirements": [
        "navmenu-open"
      ]
    }
  ]
}
