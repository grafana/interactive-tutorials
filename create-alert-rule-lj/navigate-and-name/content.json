{
  "id": "create-alert-rule-navigate-and-name",
  "title": "Navigate and name your rule",
  "blocks": [
    {
      "type": "markdown",
      "content": "Navigate to the alert rule creation page and give your rule a descriptive name."
    },
    {
      "type": "section",
      "id": "navigate-to-alerting",
      "title": "Open the alert rule creation page",
      "blocks": [
        {
          "type": "multistep",
          "content": "Navigate to **Alerting > Alert rules** from the main menu.",
          "requirements": ["navmenu-open"],
          "steps": [
            {
              "action": "highlight",
              "reftarget": "a[data-testid='data-testid Nav menu item'][href='/alerting']"
            },
            {
              "action": "highlight",
              "reftarget": "a[data-testid='data-testid Nav menu item'][href='/alerting/list']"
            }
          ]
        },
        {
          "type": "interactive",
          "action": "highlight",
          "reftarget": "a[href='/alerting/new/alerting']",
          "content": "Click **New alert rule**.",
          "requirements": ["exists-reftarget", "on-page:/alerting/list"]
        },
        {
          "type": "interactive",
          "action": "formfill",
          "reftarget": "input[id='name']",
          "targetvalue": "High request duration - Quick Pizza",
          "content": "Enter a descriptive name for your alert rule. This name appears in every notification.",
          "doIt": false,
          "requirements": ["exists-reftarget"]
        }
      ]
    },
    {
      "type": "markdown",
      "content": "Your rule has a name. Next, you'll select the data to monitor."
    }
  ]
}
