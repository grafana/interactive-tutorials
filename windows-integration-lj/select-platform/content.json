{
    "id": "windows-integration-select-platform",
    "title": "Select the Windows integration",
    "blocks": [{
            "type": "markdown",
            "content": "# Select the Windows integration\n\nYour first step on this journey is to select the Windows integration."
        },
        {
            "type": "section",
            "id": "select-windows-integration",
            "title": "Select the Windows integration",
            "blocks": [{
                    "type": "markdown",
                    "content": "Sign in to your Grafana Cloud environment, for example `mystack.grafana.net`."
                },
                {
                    "type": "multistep",
                    "content": "Navigate to **Connections > Add new connection**.",
                    "requirements": ["navmenu-open"],
                    "steps": [{
                            "action": "highlight",
                            "reftarget": "a[data-testid='data-testid Nav menu item'][href='/connections']",
                            "tooltip": "Click Connections"
                        },
                        {
                            "action": "highlight",
                            "reftarget": "a[href='/connections/add-new-connection']",
                            "tooltip": "Click Add new connection"
                        }
                    ]
                },
                {
                    "type": "interactive",
                    "action": "formfill",
                    "reftarget": "input[placeholder='Search all']",
                    "targetvalue": "Windows",
                    "content": "Search for **Windows**.",
                    "requirements": ["on-page:/connections/add-new-connection", "exists-reftarget"],
                    "skippable": true
                },
                {
                    "type": "interactive",
                    "action": "highlight",
                    "reftarget": "a[href*='/connections/add-new-connection/windows']",
                    "content": "Select the **Windows** tile.",
                    "tooltip": "Grafana Cloud uses the values you select to generate the commands you use to install Grafana Alloy on your Windows system.",
                    "requirements": ["exists-reftarget"],
                    "skippable": true
                }
            ]
        }
    ]
}