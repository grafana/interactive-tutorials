{
  "id": "knowledge-graph-guide",
  "type": "guide",
  "description": "Explore Grafana Knowledge Graph by browsing the Entity catalog and investigating issues with the RCA workbench.",
  "category": "observability",
  "author": {
    "name": "Jayclifford345",
    "team": "interactive-learning"
  },
  "startingLocation": "/a/grafana-asserts-app/catalog",
  "targeting": {
    "match": {
      "or": [
        { "urlPrefix": "/a/grafana-asserts-app/catalog" },
        { "urlPrefix": "/a/grafana-asserts-app/assertions" },
        { "urlPrefix": "/a/grafana-asserts-app/entities" },
        { "urlPrefix": "/observability" }
      ]
    }
  },
  "testEnvironment": {
    "tier": "cloud",
    "plugins": ["grafana-asserts-app"]
  },
  "depends": [
    "plugin-enabled:grafana-asserts-app"
  ]
}
